# Front-end environment config (Vite). Copy to .env to override locally.

# Where the FastAPI backend runs. The Vite dev server proxies
# /personal-context, /api/contacts, /api/action-settings,
# /api/message-history, and the dashboard file routes to this URL.
VITE_BACKEND_URL=http://localhost:8000

# Optional: call the backend at an absolute base URL instead of using
# the dev proxy (e.g. in production behind one domain). Leave empty to
# use same-origin requests + the dev proxy above.
VITE_API_BASE_URL=
